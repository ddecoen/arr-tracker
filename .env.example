# Copy to .env and fill in values. Never commit .env to git.

# Campfire API key (Settings > API Keys in Campfire)
# Role: view only is sufficient
CAMPFIRE_API_KEY=your_campfire_api_key_here

# Supabase Postgres connection string
# Format: postgres://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres
DATABASE_URL=postgres://postgres:password@localhost:5432/arr_tracker

# Port for the Go server (default 8080)
PORT=8080
